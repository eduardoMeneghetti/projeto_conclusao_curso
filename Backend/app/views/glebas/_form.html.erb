<%= form_with(model: gleba) do |form| %>
  <% if gleba.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(gleba.errors.count, "error") %> prohibited this gleba from being saved:</h2>

      <ul>
        <% gleba.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :descricao, style: "display: block" %>
    <%= form.text_field :descricao %>
  </div>

