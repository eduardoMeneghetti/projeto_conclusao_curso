<%= form_with(model: cidade) do |form| %>
  <% if cidade.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(cidade.errors.count, "error") %> prohibited this cidade from being saved:</h2>

      <ul>
        <% cidade.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :descricao, style: "display: block" %>
    <%= form.text_field :descricao %>
  </div>

  <div>
    <%= form.label :codigo_ibge, style: "display: block" %>
    <%= form.number_field :codigo_ibge %>
  </div>

  <div>
    <%= form.label :latitude, style: "display: block" %>
    <%= form.text_field :latitude %>
  </div>

  <div>
    <%= form.label :longitude, style: "display: block" %>
    <%= form.text_field :longitude %>
  </div>

  <div>
    <%= form.label :estado_id, style: "display: block" %>
    <%= form.text_field :estado_id %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
